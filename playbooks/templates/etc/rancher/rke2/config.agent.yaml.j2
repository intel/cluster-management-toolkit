server: https://{{ control_plane_ip }}:9345
container-runtime-endpoint: {{ cri_socket }}
token: {{ node_token }}
controller-manager-arg:
- feature-gates={{ controller_manager_feature_gates }}
kube-apiserver-arg:
- feature-gates={{ api_server_feature_gates }}
- runtime-config=api/alpha={{ api_server_runtime_config_api_alpha_enabled }}
kubelet-arg:
- feature-gates={{ kubelet_feature_gates }}
- cgroup-driver=systemd
kube-proxy-arg:
- feature-gates={{ kubeproxy_feature_gates }}
kube-scheduler-arg:
- feature-gates={{ scheduler_feature_gates }}
